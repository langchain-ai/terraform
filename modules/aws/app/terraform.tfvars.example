# App-specific configuration for the Terraform Helm deployment.
#
# Infrastructure values (region, cluster_name, bucket_name, etc.) are
# auto-populated by: make init-app
# Or set them manually in terraform.tfvars for "bring your own infra" scenarios.

# ── Required ──────────────────────────────────────────────────────────────────

admin_email = "admin@example.com"

# ── Optional overrides ────────────────────────────────────────────────────────

# hostname = "langsmith.example.com"   # Defaults to ALB DNS name
# chart_version = "0.7.0"              # Empty = latest
# release_name  = "langsmith"

# ── Sizing ────────────────────────────────────────────────────────────────────
# "production"       = multi-replica with HPA (~20 users, ~100 traces/sec)
# "production-large" = high-volume (~50 users, ~1000 traces/sec)
# "dev"              = single-replica, minimal resources (dev/CI/demos)
# "none"             = chart defaults

# sizing = "production"

# ── Feature toggles ──────────────────────────────────────────────────────────

# enable_agent_deploys   = true    # Deployments feature (LangGraph Platform)
# enable_agent_builder   = true    # Agent Builder (requires agent_deploys)
# enable_insights        = true    # Insights (requires ClickHouse below)
# enable_polly           = true    # Polly AI eval/monitoring (requires agent_deploys)
# enable_usage_telemetry = true    # Extended usage telemetry reporting

# ── Sandboxes ────────────────────────────────────────────────────────────────
# Requires infra enable_sandboxes = true. The infra module creates the JuiceFS
# CSI config Secret in the LangSmith namespace; pass the same Secret name here.
# Run `source infra/scripts/setup-env.sh` so the sandbox SSM secrets exist before deploy.
# Sandboxes require chart 0.16.0 or newer, and the chart version must be explicit.
#
# enable_sandboxes = true
# chart_version = "~0.16.0"
# sandbox_host_image_tag = "0.0.0"
# sandbox_service_url_base_url = "https://sandbox-services.example.com"
# sandbox_juicefs_csi_config_secret_name = "juicefs-csi-config"

# ── ClickHouse (required when enable_insights = true) ────────────────────────

# clickhouse_host     = "clickhouse.example.com"
# clickhouse_port     = 8123
# clickhouse_database = "default"
# clickhouse_username = "default"
# clickhouse_password = "changeme"
# clickhouse_tls      = true
