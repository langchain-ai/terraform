# LangSmith Insights overrides — enable when using an external ClickHouse instance.
#
# Copy to langsmith-values-insights.yaml to activate.
# deploy.sh picks it up automatically if the file is present.
#   cp langsmith-values-insights.yaml.example langsmith-values-insights.yaml
#
# Prerequisites:
#   - ClickHouse instance (AWS Marketplace, LangChain managed, or self-hosted)
#   - ClickHouse must be reachable from the EKS cluster

config:
  insights:
    enabled: true
    # encryptionKey is pulled from SSM via ESO — do not set it here.
    # Required SSM parameter: /langsmith/{prefix}-{env}/insights-encryption-key
    # Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
    # Store:    aws ssm put-parameter --name "/langsmith/{prefix}-{env}/insights-encryption-key" \
    #             --value "<key>" --type SecureString
    # deploy.sh adds this key to the langsmith-config ExternalSecret automatically.

clickhouse:
  external:
    enabled: true
    host: ""          # ClickHouse hostname or endpoint
    port: 8123        # HTTP port (default 8123); use 8443 for HTTPS
    database: "default"
    username: "default"
    password: ""      # Recommend storing in SSM: /langsmith/{prefix}-{env}/clickhouse-password
    # tls: true       # Uncomment if using HTTPS/TLS
