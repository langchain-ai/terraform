# High-availability overrides for LangSmith on AWS.
#
# Enables multi-replica deployments and autoscaling for production workloads.
# For smaller dev/test/POC deployments, use langsmith-values-dev.yaml.example instead.
#
# Copy to langsmith-values-ha.yaml to activate:
#   cp langsmith-values-ha.yaml.example langsmith-values-ha.yaml
#
# deploy.sh picks it up automatically if the file is present, applied after
# langsmith-values-{env}.yaml so these settings win.
#
# Applied on top of:
#   langsmith-values.yaml         — base AWS config (ingress, storage, auth, ESO wiring)
#   langsmith-values-{env}.yaml   — generated by init-overrides.sh (hostname, IRSA, bucket)
#
# TLS: update langsmith-values.yaml ingress annotations to enable HTTPS.
# For ACM, change listen-ports and add the certificate ARN:
#   alb.ingress.kubernetes.io/listen-ports: '[{"HTTP": 80}, {"HTTPS": 443}]'
#   alb.ingress.kubernetes.io/certificate-arn: "arn:aws:acm:<region>:<account>:certificate/<id>"
#   alb.ingress.kubernetes.io/ssl-redirect: "443"

# -- Resource sizing and autoscaling ------------------------------------------
# Tune to your workload. These are reasonable starting points for a medium
# production deployment. Monitor actual usage with:
#   kubectl top pods -n langsmith

platformBackend:
  resources:
    requests:
      cpu: "500m"
      memory: "1Gi"
    limits:
      cpu: "1"
      memory: "2Gi"
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 2
      maxReplicas: 10
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

backend:
  resources:
    requests:
      cpu: "1"
      memory: "2Gi"
    limits:
      cpu: "2"
      memory: "4Gi"
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 3
      maxReplicas: 10
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

ingestQueue:
  resources:
    requests:
      cpu: "1"
      memory: "2Gi"
    limits:
      cpu: "2"
      memory: "4Gi"
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 3
      maxReplicas: 10
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

queue:
  resources:
    requests:
      cpu: "1"
      memory: "2Gi"
    limits:
      cpu: "2"
      memory: "4Gi"
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 3
      maxReplicas: 10
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

frontend:
  resources:
    requests:
      cpu: "500m"
      memory: "1Gi"
    limits:
      cpu: "1"
      memory: "2Gi"
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 2
      maxReplicas: 10
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

playground:
  resources:
    requests:
      cpu: "500m"
      memory: "1Gi"
    limits:
      cpu: "1"
      memory: "8Gi"
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 1
      maxReplicas: 5
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

aceBackend:
  resources:
    requests:
      cpu: "200m"
      memory: "1Gi"
    limits:
      cpu: "1"
      memory: "2Gi"
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 1
      maxReplicas: 5
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80
