# AWS base Helm values for LangSmith.
#
# Copy to langsmith-values.yaml to activate:
#   cp langsmith-values.yaml.example langsmith-values.yaml
#
# This file is applied on every deploy alongside langsmith-values-{env}.yaml.
# It configures AWS-native integrations: ALB ingress, gp3 storage, S3 blob storage,
# and ESO-backed secret management.
#
# Do NOT put secrets here. Secrets are managed by External Secrets Operator (ESO),
# which syncs them from SSM into the 'langsmith-config' K8s Secret automatically.
#
# For environment-specific overrides (hostname, IRSA role ARN, bucket name, admin
# email), see langsmith-values-{env}.yaml — generated by init-overrides.sh.

ingress:
  enabled: true
  ingressClassName: alb
  annotations:
    kubernetes.io/ingress.class: alb
    alb.ingress.kubernetes.io/scheme: internet-facing  # Set to "internal" for private clusters
    alb.ingress.kubernetes.io/target-type: ip
    alb.ingress.kubernetes.io/listen-ports: '[{"HTTP": 80}]'
    # For HTTPS (ACM): update listen-ports and add the certificate ARN:
    #   alb.ingress.kubernetes.io/listen-ports: '[{"HTTP": 80}, {"HTTPS": 443}]'
    #   alb.ingress.kubernetes.io/certificate-arn: "arn:aws:acm:<region>:<account>:certificate/<id>"
    #   alb.ingress.kubernetes.io/ssl-redirect: "443"

storage:
  storageClassName: gp3

config:
  authType: "mixed"
  # Secrets are managed by External Secrets Operator (ESO) — not stored in this file.
  # ESO syncs the 'langsmith-config' K8s Secret from SSM prefix:
  #   /langsmith/{name_prefix}-{environment}/
  #
  # Auto-created by setup-env.sh (run before deploy):
  #   langsmith-license-key       → langsmith_license_key
  #   langsmith-api-key-salt      → api_key_salt
  #   langsmith-jwt-secret        → jwt_secret
  #   langsmith-admin-password    → initial_org_admin_password
  #
  # Required manually before enabling addons (see each addon file for instructions):
  #   agent-builder-encryption-key  → agent_builder_encryption_key  (agent-builder addon)
  #   insights-encryption-key       → insights_encryption_key        (insights addon)
  existingSecretName: "langsmith-config"
  basicAuth:
    enabled: true
    # IMPORTANT: jwtSecret must be at config.basicAuth.jwtSecret — NOT config.jwtSecret.
    # Placing it at the top level of config silently passes Helm validation but does not
    # wire correctly. The value is injected via existingSecretName as the 'jwt_secret' key.
  blobStorage:
    enabled: true
    engine: "S3"

postgres:
  external:
    enabled: true
    existingSecretName: "langsmith-postgres"
    connectionUrlSecretKey: "connection_url"

redis:
  external:
    enabled: true
    existingSecretName: "langsmith-redis"
    connectionUrlSecretKey: "connection_url"
