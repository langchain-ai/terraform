Legend [icon: shield, color: gray] {
  Sync Data Path [icon: server, color: blue]
  Async or Management Path [icon: server, color: gray]
  Core LangSmith blue [icon: server, color: blue]
  LangGraph Deployments opt-in green [icon: server, color: green]
  Agent Builder opt-in pink [icon: server, color: pink]
  Operator Managed Pods orange [icon: server, color: gray]
  In-Cluster Dev Only red [icon: database, color: red]
  Infrastructure Controllers gray [icon: kubernetes, color: gray]
  Gateway Controllers purple [icon: server, color: purple]
  Secrets and ESO green [icon: lock, color: green]
  External AWS Services [icon: aws-rds, color: blue]
}
