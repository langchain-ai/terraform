// LEGEND
// ============================================================
Legend [icon: shield, color: gray] {
  Sync Data Path [icon: server, color: blue]
  Async or Management Path [icon: server, color: gray]
  Core LangSmith Services [icon: server, color: blue]
  LangGraph Deployments optional [icon: server, color: green]
  Agent Builder optional [icon: server, color: pink]
  Operator Managed Pods [icon: server, color: gray]
  In-Cluster Dev Only Data [icon: database, color: red]
  External Production Data [icon: database, color: blue]
  Secrets and IAM [icon: lock, color: green]
  Gateway Controllers [icon: server, color: purple]
  Required Egress [icon: globe, color: orange]
  S3 VPC Gateway No NAT [icon: aws-simple-storage-service, color: green]
}
