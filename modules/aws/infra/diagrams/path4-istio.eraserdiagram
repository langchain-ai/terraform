// LEGEND
// ============================================================
Legend [icon: shield, color: gray] {
  // > sync connection (request path)
  SyncTrafficPath [icon: server, color: blue]
  // --> async or management connection
  AsyncOrControlPlane [icon: server, color: gray]
  TLSCertFlow [icon: shield, color: green]
  IstioDataPlane [icon: kubernetes, color: blue]
  GatewayAPIResources [icon: kubernetes, color: orange]
}
