# Terraform state and working directories
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Terraform variable files (keep examples, ignore actuals)
*.tfvars
*.auto.tfvars.json
!*.tfvars.example
secrets.auto.tfvars

# Terraform plan outputs
plan.out

# Local secret files generated by setup-env.sh
# These are created before SSM is reachable and migrated after Pass 1
infra/.pg_password
infra/.api_key_salt
infra/.jwt_secret
infra/.license_key
infra/.admin_password
infra/.admin_email

# Helm generated values — contain real credentials
**/helm/values/langsmith-values*.yaml
!**/helm/values/langsmith-values*.yaml.example
**/values-overrides.yaml

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Test reports and run artifacts
reports/test-runs/
reports/infrastructure/
reports
# OS artifacts
.DS_Store
