# GCP environment-specific overrides for LangSmith.
#
# This file is generated automatically by init-values.sh.
# Manual: copy this example to values-overrides.yaml and fill in required fields.
#
# Applied after values.yaml on every deploy — last value wins.
# Do NOT put GCP infrastructure config here (Gateway, blob storage engine, etc.) — that's in values.yaml.

config:
  # Required: set your domain
  hostname: "langsmith.example.com"

  # Required: first-login admin credentials
  basicAuth:
    initialOrgAdminEmail: "admin@example.com"
    initialOrgAdminPassword: "CHANGE_ME"

  # Required: GCS HMAC credentials for blob storage
  # Create HMAC key in GCP Console: Storage → Settings → Interoperability
  # Or use Workload Identity if your chart version supports native GCS auth.
  blobStorage:
    bucketName: ""       # terraform output -raw storage_bucket_name
    accessKey: ""        # GCS HMAC access key
    accessKeySecret: ""  # GCS HMAC secret

gateway:
  name: ""  # terraform output -raw gateway_name  (e.g. myco-prod-gateway)

# Workload Identity annotation is applied per-component by init-values.sh.
# Example (generated by init-values.sh):
# backend:
#   serviceAccount:
#     annotations:
#       iam.gke.io/gcp-service-account: "myco-langsmith@my-project.iam.gserviceaccount.com"
