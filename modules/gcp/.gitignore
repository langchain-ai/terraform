# Terraform state and working directories
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Terraform variable files (keep examples, ignore actuals)
*.tfvars
*.auto.tfvars.json
!*.tfvars.example
secrets.auto.tfvars

# Terraform plan outputs
plan.out

# Local secret files — generated before Secret Manager is reachable
infra/.pg_password
infra/.api_key_salt
infra/.jwt_secret
infra/.license_key
infra/.admin_password
infra/.admin_email

# Helm generated values — contain real credentials
**/helm/values/langsmith-values*.yaml
!**/helm/values/langsmith-values*.yaml.example
**/values-overrides.yaml

# Generated module artifacts
infra/modules/**/external-ip.txt
infra/modules/**/gateway-class.yaml
infra/modules/**/gateway.yaml
infra/modules/**/reference-grant.yaml
infra/modules/**/certificate.yaml
infra/modules/**/letsencrypt-issuer.yaml

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# OS artifacts
.DS_Store
