# Terraform state and working directories
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Terraform variable files (keep examples, ignore actuals)
*.tfvars
*.auto.tfvars.json
!*.tfvars.example
secrets.auto.tfvars

# Terraform plan outputs
*.json
plan.out

# Local secret files generated before Key Vault exists
infra/.api_key_salt
infra/.jwt_secret
infra/.deployments_key
infra/.agent_builder_key
infra/.insights_key

# Helm generated values — contain real credentials
**/helm/values/langsmith-values*.yaml
!**/helm/values/langsmith-values*.yaml.example
**/values-overrides.yaml

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# OS artifacts
.DS_Store
