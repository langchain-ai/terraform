# Generated secrets file — contains plaintext credentials, never commit
secrets.auto.tfvars

# Local secret fallback files — generated before Key Vault exists, migrated after Pass 1
.api_key_salt
.jwt_secret
.deployments_key
.agent_builder_key
.insights_key

# Operator-specific Terraform state and vars
terraform.tfvars
terraform.tfstate
terraform.tfstate.backup
.terraform/
.terraform.lock.hcl

# Terraform plan outputs — can contain credentials in plaintext
*.json
plan.out
