# =============================================================================
# LangSmith on Azure — Minimum Profile
# =============================================================================
# ABSOLUTE MINIMUM — NOT FOR ANY REAL WORKLOAD.
#
# Smallest possible footprint: Standard_D4s_v3 nodes, in-cluster Postgres and
# Redis, minimum Helm sizing. Exists to keep LangSmith alive at the lowest
# possible cost for demos, CI smoke tests, or single-user POCs.
#
# Will break under any meaningful traffic. OOM kills, timeouts, and degraded
# UX are expected and acceptable.
#
# Copy to terraform.tfvars and fill in your values:
#
#   cp terraform.tfvars.minimum terraform.tfvars
#
# For the full annotated reference with every option explained, see:
#   terraform.tfvars.example
# =============================================================================

#------------------------------------------------------------------------------
# REQUIRED — Change these
#------------------------------------------------------------------------------
subscription_id = "your-azure-subscription-id"   # az account show --query id -o tsv

#------------------------------------------------------------------------------
# Naming
#------------------------------------------------------------------------------
identifier  = "-demo"      # suffix appended to every resource name
environment = "dev"
location    = "eastus"

#------------------------------------------------------------------------------
# Sources — in-cluster for minimum footprint
#------------------------------------------------------------------------------
postgres_source   = "in-cluster"
redis_source      = "in-cluster"
clickhouse_source = "in-cluster"

#------------------------------------------------------------------------------
# AKS — single Standard_D4s_v3 node (4 vCPU / 16 GiB), scales to 3
#------------------------------------------------------------------------------
default_node_pool_vm_size   = "Standard_D4s_v3"   # 4 vCPU, 16 GiB — absolute floor
default_node_pool_min_count = 1
default_node_pool_max_count = 3
default_node_pool_max_pods  = 60
aks_deletion_protection     = false

# No large pool needed — in-cluster ClickHouse runs on the default pool
additional_node_pools = {}

#------------------------------------------------------------------------------
# Ingress
#------------------------------------------------------------------------------
ingress_controller = "nginx"

#------------------------------------------------------------------------------
# DNS + TLS — Public IP DNS label + Let's Encrypt HTTP-01
#------------------------------------------------------------------------------
dns_label        = "langsmith-min"        # → langsmith-min.eastus.cloudapp.azure.com
tls_certificate_source = "letsencrypt"
letsencrypt_email      = "you@example.com"

#------------------------------------------------------------------------------
# Key Vault
#------------------------------------------------------------------------------
keyvault_purge_protection = false

#------------------------------------------------------------------------------
# Blob storage — short retention
#------------------------------------------------------------------------------
blob_ttl_enabled    = true
blob_ttl_short_days = 7
blob_ttl_long_days  = 30     # short retention — this isn't production data

#------------------------------------------------------------------------------
# LangSmith
#------------------------------------------------------------------------------
langsmith_namespace    = "langsmith"
langsmith_release_name = "langsmith"

#------------------------------------------------------------------------------
# Sizing — minimum profile (rock-bottom resource requests)
#------------------------------------------------------------------------------
sizing_profile = "minimum"
