# =============================================================================
# LangSmith on Azure — Production Profile
# =============================================================================
# Opinionated defaults for production deployments.
# External Postgres + Redis + Blob, in-cluster ClickHouse (or use LangChain
# Managed ClickHouse for full production — see terraform.tfvars.example).
#
# Copy to terraform.tfvars and fill in your values:
#
#   cp terraform.tfvars.production terraform.tfvars
#
# For the full annotated reference with every option explained, see:
#   terraform.tfvars.example
# =============================================================================

#------------------------------------------------------------------------------
# REQUIRED — Change these
#------------------------------------------------------------------------------
subscription_id = "your-azure-subscription-id"   # az account show --query id -o tsv

#------------------------------------------------------------------------------
# Naming
#------------------------------------------------------------------------------
identifier  = "-prod"
environment = "prod"
location    = "eastus"   # pick the region closest to your users

#------------------------------------------------------------------------------
# Sources
#------------------------------------------------------------------------------
postgres_source   = "external"     # Azure DB for PostgreSQL Flexible Server
redis_source      = "external"     # Azure Cache for Redis
clickhouse_source = "in-cluster"   # use LangChain Managed ClickHouse for full prod

#------------------------------------------------------------------------------
# PostgreSQL — production grade, deletion protection on
#------------------------------------------------------------------------------
postgres_admin_username      = "langsmith"
postgres_database_name       = "langsmith"
postgres_deletion_protection = true   # must set false before terraform destroy

#------------------------------------------------------------------------------
# Redis
#------------------------------------------------------------------------------
redis_capacity = 1   # P1 = 6 GB RAM; increase to P2 (13 GB) for high write load

#------------------------------------------------------------------------------
# AKS — Standard_D8s_v3 (8 vCPU, 32 GiB), 3 nodes minimum
#------------------------------------------------------------------------------
# 3× Standard_D8s_v3 = 18,870m allocatable vCPU.
# Pass 2–5 (all features) requires ~17.9 vCPU — fits at 95% utilization.
# Autoscaler handles burst; increase min_count to 5 if enabling Pass 3+.
#
# CPU requests at production sizing (all passes):
#   backend ×3 (3.0) + platformBackend ×2 (1.0) + ingestQueue ×3 (3.0)
#   + queue ×3 (3.0) + frontend ×2 (1.0) + playground (0.5) + aceBackend (0.2)
#   + hostBackend ×2 (1.0) + listener ×2 (1.0) + operator (0.5)
#   + agentBuilder ×2 (1.0) + clickhouse (2.0) + system (0.65) = ~17.9 vCPU
default_node_pool_vm_size   = "Standard_D8s_v3"
default_node_pool_min_count = 3     # minimum 3 for Pass 2; set 5 for Pass 3+
default_node_pool_max_count = 10
default_node_pool_max_pods  = 60
aks_deletion_protection     = true   # must set false before terraform destroy

# Large pool: for ClickHouse isolation + LangGraph agent deployment pods (Pass 3+)
additional_node_pools = {
  large = {
    vm_size   = "Standard_D16s_v3"   # 16 vCPU, 64 GiB
    min_count = 0                     # scales from zero — not needed for Pass 2 alone
    max_count = 2
  }
}

#------------------------------------------------------------------------------
# Ingress
#------------------------------------------------------------------------------
ingress_controller = "nginx"

#------------------------------------------------------------------------------
# DNS + TLS — Public IP DNS label + Let's Encrypt HTTP-01
#   Works with all ingress controllers (nginx, istio, istio-addon, envoy-gateway).
#   → https://<dns_label>.<location>.cloudapp.azure.com
#   For custom domain: swap to tls_certificate_source = "dns01" + langsmith_domain
#------------------------------------------------------------------------------
dns_label        = "langsmith-prod"       # → langsmith-prod.eastus.cloudapp.azure.com
tls_certificate_source = "letsencrypt"
letsencrypt_email      = "you@example.com"

#------------------------------------------------------------------------------
# Key Vault
#------------------------------------------------------------------------------
keyvault_purge_protection = true   # required for production

#------------------------------------------------------------------------------
# Blob storage — production retention
#------------------------------------------------------------------------------
blob_ttl_enabled    = true
blob_ttl_short_days = 14    # short-lived trace payloads
blob_ttl_long_days  = 400   # run attachments (~13 months)

#------------------------------------------------------------------------------
# LangSmith
#------------------------------------------------------------------------------
langsmith_namespace    = "langsmith"
langsmith_release_name = "langsmith"

#------------------------------------------------------------------------------
# Sizing — production (multi-replica + HPA)
#------------------------------------------------------------------------------
sizing_profile = "production"

# Pass 3 — LangGraph Platform
# enable_deployments = true

# Pass 4 — Agent Builder
# enable_agent_builder = true

# Pass 5 — Insights / Polly
# enable_insights = true
# enable_polly    = true

#------------------------------------------------------------------------------
# Optional add-ons — recommended for production
#------------------------------------------------------------------------------
# create_diagnostics = true   # Log Analytics + diagnostic settings
# create_waf         = true   # Azure WAF policy (OWASP 3.2 + bot protection)

#------------------------------------------------------------------------------
# Multi-AZ — for zone-redundant HA (optional)
#------------------------------------------------------------------------------
# availability_zones                 = ["1", "2", "3"]
# postgres_standby_availability_zone = "2"
# postgres_geo_redundant_backup      = true
