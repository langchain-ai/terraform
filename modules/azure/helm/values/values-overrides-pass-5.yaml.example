# LangSmith Azure — Pass 5: Insights (Clio)
#
# Adds to Pass 3: Insights AI agent (runs as a LangGraph deployment via operator)
#                 No additional static pods — Clio deploys dynamically.
#
# Prerequisites:
#   - Pass 3 deployed and healthy (host-backend, listener, operator running)
#   - langsmith-insights-encryption-key in langsmith-config-secret (set in Pass 2c)
#
# WARNING: Never change insights_encryption_key after first enable — it will
#          permanently break access to existing insights data.
#
# HOW TO USE:
#   cp values-overrides-pass-5.yaml.example values-overrides.yaml
#   Fill every <placeholder> with real values from terraform outputs.
#   values-overrides.yaml is gitignored — never commit it.
#
# HELM COMMAND:
#   helm upgrade --install langsmith langsmith/langsmith \
#     --version <VERSION> --namespace langsmith \
#     -f helm/values/values-overrides.yaml \
#     --wait --timeout 15m

config:
  hostname: "<your-domain.com>"
  authType: "mixed"
  initialOrgAdminEmail: "<admin@example.com>"
  existingSecretName: "langsmith-config-secret"
  basicAuth:
    enabled: true
  blobStorage:
    enabled: true
    engine: "Azure"
    azureStorageAccountName: "<tf output: storage_account_name>"
    azureStorageContainerName: "<tf output: storage_container_name>"
  telemetry:
    usageReporting: true
  deployment:
    enabled: true
    url: "https://<your-domain.com>"
  # Pass 5 — encryption keys read from langsmith-config-secret
  # WARNING: never change after first deploy
  insights:
    enabled: true
  polly:
    enabled: true

postgres:
  external:
    enabled: true
    existingSecretName: "langsmith-postgres-secret"
    connectionUrlSecretKey: "connection_url"

redis:
  external:
    enabled: true
    existingSecretName: "langsmith-redis-secret"
    connectionUrlSecretKey: "connection_url"

backend:
  deployment:
    replicas: 1
    labels:
      azure.workload.identity/use: "true"
    resources:
      requests: { cpu: 1000m, memory: 2000Mi }
      limits:   { cpu: 2000m, memory: 4Gi }
  serviceAccount:
    annotations:
      azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 3
      maxReplicas: 10
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

platformBackend:
  deployment:
    replicas: 1
    labels:
      azure.workload.identity/use: "true"
    resources:
      requests: { cpu: 500m, memory: 1Gi }
      limits:   { cpu: 1000m, memory: 2Gi }
  serviceAccount:
    annotations:
      azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 1
      maxReplicas: 10
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

frontend:
  service:
    type: ClusterIP
  deployment:
    resources:
      requests: { cpu: 500m, memory: 1Gi }
      limits:   { cpu: 1000m, memory: 2Gi }
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 1
      maxReplicas: 10
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

playground:
  deployment:
    resources:
      requests: { cpu: 500m, memory: 1Gi }
      limits:   { cpu: 1000m, memory: 2Gi }
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 1
      maxReplicas: 10
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

queue:
  deployment:
    replicas: 1
    labels:
      azure.workload.identity/use: "true"
    resources:
      requests: { cpu: 1000m, memory: 2Gi }
      limits:   { cpu: 2000m, memory: 4Gi }
  serviceAccount:
    annotations:
      azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 3
      maxReplicas: 10
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

ingestQueue:
  enabled: true
  deployment:
    replicas: 1
    labels:
      azure.workload.identity/use: "true"
    resources:
      requests: { cpu: 1000m, memory: 2Gi }
      limits:   { cpu: 2000m, memory: 4Gi }
  serviceAccount:
    annotations:
      azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 3
      maxReplicas: 10
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

aceBackend:
  deployment:
    resources:
      requests: { cpu: 500m, memory: 1Gi }
      limits:   { cpu: 1000m, memory: 2Gi }
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 1
      maxReplicas: 5
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

clickhouse:
  statefulSet:
    resources:
      requests: { cpu: 3500m, memory: 15Gi }
      limits:   { cpu: 8000m, memory: 32Gi }
    persistence:
      size: "500Gi"

ingress:
  enabled: true
  ingressClassName: "nginx"
  annotations:
    cert-manager.io/cluster-issuer: "letsencrypt-prod"
  tls:
    - secretName: langsmith-tls
      hosts:
        - "<your-domain.com>"

# ── Pass 3 additions ──────────────────────────────────────────────────────────
hostBackend:
  enabled: true
  deployment:
    labels:
      azure.workload.identity/use: "true"
    resources:
      requests: { cpu: 100m, memory: 500Mi }
  serviceAccount:
    annotations:
      azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"

listener:
  enabled: true
  deployment:
    labels:
      azure.workload.identity/use: "true"
    resources:
      requests: { cpu: 100m, memory: 500Mi }
  serviceAccount:
    annotations:
      azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"

operator:
  enabled: true
  templates:
    deployment: |
      apiVersion: apps/v1
      kind: Deployment
      metadata:
        name: ${name}
        namespace: ${namespace}
      spec:
        replicas: ${replicas}
        revisionHistoryLimit: 10
        selector:
          matchLabels:
            app: ${name}
        template:
          metadata:
            labels:
              app: ${name}
              azure.workload.identity/use: "true"
          spec:
            enableServiceLinks: false
            serviceAccountName: langsmith-ksa
            containers:
            - name: api-server
              image: ${image}
              ports:
              - name: api-server
                containerPort: 8000
                protocol: TCP
              livenessProbe:
                httpGet:
                  path: /ok
                  port: 8000
                periodSeconds: 15
                timeoutSeconds: 5
                failureThreshold: 6
              readinessProbe:
                httpGet:
                  path: /ok
                  port: 8000
                periodSeconds: 15
                timeoutSeconds: 5
                failureThreshold: 6
              resources:
                requests:
                  cpu: 100m
                  memory: 256Mi
                limits:
                  cpu: 1000m
                  memory: 1Gi
