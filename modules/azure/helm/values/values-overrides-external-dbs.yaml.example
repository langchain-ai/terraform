# LangSmith Azure — Helm values overrides (External Postgres + Redis)
#
# Use this file when terraform.tfvars has:
#   postgres_source = "external"
#   redis_source    = "external"
#
# HOW TO USE:
#   cp values-overrides-external-dbs.yaml.example values-overrides.yaml
#   Fill every <placeholder> with real values (terraform outputs + Key Vault).
#   Uncomment Pass 3 / 4 / 5 sections as you progress.
#   values-overrides.yaml is gitignored — never commit it.
#
# HELM COMMAND (same for every pass — single -f flag):
#   helm upgrade --install langsmith langsmith/langsmith \
#     --version <VERSION> \
#     --namespace langsmith \
#     -f helm/values/values-overrides.yaml \
#     --wait --timeout 15m

# ── Pass 2 — Core LangSmith ───────────────────────────────────────────────────
config:
  hostname: "<your-domain.com>"             # e.g. 1-2-3-4.sslip.io or langsmith.example.com
  authType: "mixed"                         # mixed = basic auth + API keys
  initialOrgAdminEmail: "<admin@example.com>"
  existingSecretName: "langsmith-config-secret"

  basicAuth:
    enabled: true

  # Azure Blob Storage — Workload Identity auth, no static key needed
  blobStorage:
    enabled: true
    engine: "Azure"
    azureStorageAccountName: "<tf output: storage_account_name>"
    azureStorageContainerName: "<tf output: storage_container_name>"

  # ── Pass 3 — LangGraph Platform (Deployments) ──────────────────────────────
  # Uncomment this block when enabling Pass 3.
  # deployment:
  #   enabled: true
  #   url: "https://<your-domain.com>"      # must match config.hostname above

  # ── Pass 4 — Agent Builder ─────────────────────────────────────────────────
  # Uncomment this block when enabling Pass 4.
  # agentBuilder:
  #   enabled: true
  #   # encryptionKey read from langsmith-config-secret (agent_builder_encryption_key)

  # ── Pass 5 — Insights ──────────────────────────────────────────────────────
  # Uncomment this block when enabling Pass 5.
  # insights:
  #   enabled: true
  #   # encryptionKey read from langsmith-config-secret (insights_encryption_key)

# ── External PostgreSQL ───────────────────────────────────────────────────────
# Azure DB for PostgreSQL Flexible Server — created by Terraform, secret by k8s-bootstrap.
postgres:
  external:
    enabled: true
    existingSecretName: "langsmith-postgres-secret"
    connectionUrlSecretKey: "connection_url"

# ── External Redis ────────────────────────────────────────────────────────────
# Azure Cache for Redis Premium — created by Terraform, secret by k8s-bootstrap.
redis:
  external:
    enabled: true
    existingSecretName: "langsmith-redis-secret"
    connectionUrlSecretKey: "connection_url"

# ── Pass 2 pods — Workload Identity + resources ───────────────────────────────
# WI label + client-id annotation required on every pod that accesses Blob Storage.
# Resources from helm/charts/langsmith/examples/medium_size.yaml

backend:
  deployment:
    replicas: 1
    labels:
      azure.workload.identity/use: "true"
    resources:
      requests:
        cpu: 1000m
        memory: 2000Mi
      limits:
        cpu: 2000m
        memory: 4Gi
  serviceAccount:
    annotations:
      azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 3
      maxReplicas: 10
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

platformBackend:
  deployment:
    replicas: 1
    labels:
      azure.workload.identity/use: "true"
    resources:
      requests:
        cpu: 500m
        memory: 1Gi
      limits:
        cpu: 1000m
        memory: 2Gi
  serviceAccount:
    annotations:
      azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 1
      maxReplicas: 10
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

frontend:
  service:
    type: ClusterIP
  deployment:
    resources:
      requests:
        cpu: 500m
        memory: 1Gi
      limits:
        cpu: 1000m
        memory: 2Gi
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 1
      maxReplicas: 10
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

playground:
  deployment:
    resources:
      requests:
        cpu: 500m
        memory: 1Gi
      limits:
        cpu: 1000m
        memory: 2Gi
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 1
      maxReplicas: 10
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

queue:
  deployment:
    replicas: 1
    labels:
      azure.workload.identity/use: "true"
    resources:
      requests:
        cpu: 1000m
        memory: 2Gi
      limits:
        cpu: 2000m
        memory: 4Gi
  serviceAccount:
    annotations:
      azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 3
      maxReplicas: 10
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

ingestQueue:
  enabled: true
  deployment:
    replicas: 1
    labels:
      azure.workload.identity/use: "true"
    resources:
      requests:
        cpu: 1000m
        memory: 2Gi
      limits:
        cpu: 2000m
        memory: 4Gi
  serviceAccount:
    annotations:
      azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 3
      maxReplicas: 10
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

aceBackend:
  deployment:
    resources:
      requests:
        cpu: 500m
        memory: 1Gi
      limits:
        cpu: 1000m
        memory: 2Gi
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 1
      maxReplicas: 5
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

# ── ClickHouse (always in-cluster) ───────────────────────────────────────────
clickhouse:
  statefulSet:
    resources:
      requests:
        cpu: 3500m
        memory: 15Gi
      limits:
        cpu: 8000m
        memory: 32Gi
    persistence:
      size: "500Gi"

# ── Ingress (NGINX + cert-manager) ───────────────────────────────────────────
ingress:
  enabled: true
  ingressClassName: "nginx"
  annotations:
    cert-manager.io/cluster-issuer: "letsencrypt-prod"
  tls:
    - secretName: langsmith-tls
      hosts:
        - "<your-domain.com>"               # must match config.hostname

# ── Pass 3 — LangGraph Platform (Deployments) ────────────────────────────────
# Uncomment this entire section when enabling Pass 3.
# Adds: hostBackend (control plane), listener (CRD watcher), operator (K8s manager)
# Requires: KEDA installed (Pass 1 Terraform), ingress with hostname configured above.
#
# hostBackend:
#   enabled: true
#   deployment:
#     labels:
#       azure.workload.identity/use: "true"
#     resources:
#       requests: { cpu: "100m", memory: "500Mi" }
#   serviceAccount:
#     annotations:
#       azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"
#
# listener:
#   enabled: true
#   deployment:
#     labels:
#       azure.workload.identity/use: "true"
#     resources:
#       requests: { cpu: "100m", memory: "500Mi" }
#   serviceAccount:
#     annotations:
#       azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"
#
# operator:
#   enabled: true
#   # Azure deployment template — adds WI label + langsmith-ksa service account
#   # so every LangGraph agent deployment pod can access Blob Storage.
#   templates:
#     deployment: |
#       apiVersion: apps/v1
#       kind: Deployment
#       metadata:
#         name: ${name}
#         namespace: ${namespace}
#       spec:
#         replicas: ${replicas}
#         revisionHistoryLimit: 10
#         selector:
#           matchLabels:
#             app: ${name}
#         template:
#           metadata:
#             labels:
#               app: ${name}
#               azure.workload.identity/use: "true"
#           spec:
#             enableServiceLinks: false
#             serviceAccountName: langsmith-ksa
#             containers:
#             - name: api-server
#               image: ${image}
#               ports:
#               - name: api-server
#                 containerPort: 8000
#                 protocol: TCP
#               livenessProbe:
#                 httpGet:
#                   path: /ok
#                   port: 8000
#                 periodSeconds: 15
#                 timeoutSeconds: 5
#                 failureThreshold: 6
#               readinessProbe:
#                 httpGet:
#                   path: /ok
#                   port: 8000
#                 periodSeconds: 15
#                 timeoutSeconds: 5
#                 failureThreshold: 6
#               resources:
#                 requests:
#                   cpu: 100m
#                   memory: 256Mi
#                 limits:
#                   cpu: 1000m
#                   memory: 1Gi

# ── Pass 4 — Agent Builder ────────────────────────────────────────────────────
# Uncomment this entire section when enabling Pass 4.
# Requires Pass 3 to be running.
# Fernet key is read from langsmith-config-secret (agent_builder_encryption_key).
#
# backend:
#   agentBootstrap:
#     enabled: true   # Job that registers the bundled Agent Builder agent
#
# agentBuilderToolServer:
#   enabled: true
#   deployment:
#     labels:
#       azure.workload.identity/use: "true"
#     resources:
#       requests: { cpu: "100m", memory: "500Mi" }
#   serviceAccount:
#     annotations:
#       azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"
#
# agentBuilderTriggerServer:
#   enabled: true
#   deployment:
#     labels:
#       azure.workload.identity/use: "true"
#     resources:
#       requests: { cpu: "100m", memory: "500Mi" }
#   serviceAccount:
#     annotations:
#       azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"

# ── Pass 5 — Insights ─────────────────────────────────────────────────────────
# Uncomment this entire section when enabling Pass 5.
# Requires Pass 3 to be running.
# Fernet key is read from langsmith-config-secret (insights_encryption_key).
# WARNING: Never change the encryption key after first deploy — breaks existing data.
#
# No additional pods — Insights runs as a LangGraph deployment via the operator.
# The config.insights block above (in config:) is all that's needed.
