# LangGraph Dataplane — Workspace 1 / ISOLATED NAMESPACE
#
# Each dataplane runs in its own namespace with an independent listener + operator.
# The operator lease is namespace-scoped — no competition with other dataplanes.
#
# Listener: obtain UUID from LangSmith UI → Settings → Deployments → Listeners
# Workspace: obtain UUID from LangSmith UI → Settings → Workspace
# Agent namespace: agents-build-one (must exist before helm install)
#
# HELM COMMAND:
#   helm upgrade --install langgraph-dataplane-ws1 langchain/langgraph-dataplane \
#     --namespace langgraph-dataplane-ws1 \
#     --values terraform/azure/helm/values/use-cases/multi-dataplane-listener-and-operator/values-dp-ws1.yaml.example \
#     --wait
#
# CHECK LEASE:
#   kubectl logs -n langgraph-dataplane-ws1 deploy/langgraph-dataplane-ws1-operator | grep lease
#   # → successfully acquired lease langgraph-dataplane-ws1/b578d67b.langchain.ai

config:
  langsmithApiKey: "<langsmith API key for workspace 1>"
  langsmithWorkspaceId: "<workspace-1-uuid from LangSmith UI>"
  hostBackendUrl: "http://langsmith-host-backend.langsmith.svc.cluster.local:1985"
  smithBackendUrl: "http://langsmith-platform-backend.langsmith.svc.cluster.local:1986"
  langgraphListenerId: "<listener-1-uuid from LangSmith UI>"
  # watchNamespaces must match the agent namespace where this workspace's agent pods land.
  # The operator will only reconcile LGP CRDs in this namespace.
  # Each workspace must have its own dedicated agent namespace.
  watchNamespaces: "agents-build-one"
  enableLGPDeploymentHealthCheck: true

ingress:
  enabled: false

istioGateway:
  enabled: true
  name: "langsmith-gateway"
  namespace: "aks-istio-ingress"   # ASM addon: ingress gateway lives in aks-istio-ingress (not istio-system)

operator:
  enabled: true
  createCRDs: false   # CRD is cluster-scoped — only install once, never let
                      # individual operators fight over it. See README for CRD management.
  kedaEnabled: true
  watchNamespaces: "agents-build-one"
  deployment:
    replicas: 2     # HA — one holds the lease, second takes over on failure (~15s)
  templates:
    deployment: |
      apiVersion: apps/v1
      kind: Deployment
      metadata:
        name: ${name}
        namespace: ${namespace}
      spec:
        replicas: ${replicas}
        revisionHistoryLimit: 10
        selector:
          matchLabels:
            app: ${name}
        template:
          metadata:
            labels:
              app: ${name}
              azure.workload.identity/use: "true"
          spec:
            enableServiceLinks: false
            serviceAccountName: langsmith-ksa
            containers:
            - name: api-server
              image: ${image}
              envFrom:
              - secretRef:
                  name: ${name}-secrets
              - secretRef:
                  name: langsmith-agent-builder-env
                  optional: true
              env:
              - name: LANGSMITH_WORKSPACE_ID
                value: "<workspace-1-uuid>"
              # Override: LANGCHAIN_ENDPOINT must point to legacy backend (1984) not
              # platform-backend (1986). Polly fetches /api/v1/workspaces/current/secrets/encrypted
              # which only exists on backend:1984. Must appear BEFORE the LGP-injected
              # LANGCHAIN_ENDPOINT so first-occurrence wins in the container env.
              - name: LANGCHAIN_ENDPOINT
                value: "http://langsmith-backend.langsmith.svc.cluster.local:1984"
              ports:
              - name: api-server
                containerPort: 8000
                protocol: TCP
              livenessProbe:
                httpGet: { path: /ok, port: 8000 }
                periodSeconds: 15
                timeoutSeconds: 5
                failureThreshold: 6
              readinessProbe:
                httpGet: { path: /ok, port: 8000 }
                periodSeconds: 15
                timeoutSeconds: 5
                failureThreshold: 6
              resources:
                requests: { cpu: 100m, memory: 256Mi }
                limits:   { cpu: 1000m, memory: 1Gi }

listener:
  deployment:
    labels:
      azure.workload.identity/use: "true"
    resources:
      requests: { cpu: "1000m", memory: "2Gi" }
      limits:   { cpu: "2000m", memory: "4Gi" }
  serviceAccount:
    annotations:
      azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"
