# LangSmith Control Plane — Isolated Dataplane Namespaces Setup
#
# Each dataplane runs in its own namespace (langgraph-dataplane-wsN)
# with an independent listener + operator. The CP has neither.
#
# All traffic via Istio Gateway.
#
# HELM COMMAND:
#   helm upgrade --install langsmith langsmith/langsmith \
#     --namespace langsmith \
#     --version <VERSION> \
#     --values terraform/azure/helm/values/use-cases/multi-dataplane-listener-and-operator/values-cp.yaml.example \
#     --timeout 15m

config:
  hostname: "https://<tf output: ingress_lb_ip or your-domain.com>"
  authType: "mixed"
  initialOrgAdminEmail: "<admin@example.com>"
  existingSecretName: "langsmith-config-secret"
  basicAuth:
    enabled: true
  # ── OAuth / OIDC (optional — replace basicAuth) ───────────────────────────
  # Uncomment and fill in to enable SSO via an OIDC provider (e.g. Okta, Entra ID).
  # When oauth.enabled is true, set basicAuth.enabled: false above.
  # oauth:
  #   enabled: true
  #   oauthClientId: "<oauth-client-id>"
  #   oauthClientSecret: "<oauth-client-secret>"
  #   oauthIssuerUrl: "<https://your-idp-issuer-url>"
  #   oauthScopes: "openid,email,profile,offline_access"
  blobStorage:
    enabled: true
    engine: "Azure"
    azureStorageAccountName: "<tf output: storage_account_name>"
    azureStorageContainerName: "<tf output: storage_container_name>"

  deployment:
    enabled: true
    url: "https://<tf output: ingress_lb_ip or your-domain.com>"

  # Primary workspace listener ID — used by backend for agent-builder routing.
  # Obtain from LangSmith UI: Settings → Deployments → Listeners.
  langgraphListenerId: "<listener UUID from LangSmith UI>"
  agentBuilder:
    enabled: true

  # WARNING: insights_encryption_key must never change after first enable
  insights:
    enabled: true

  # WARNING: polly_encryption_key must never change after first enable
  polly:
    enabled: true
    agent:
      extraEnv:
        # LANGCHAIN_ENDPOINT must point to legacy backend (1984) not platform-backend (1986).
        # Polly fetches /api/v1/workspaces/current/secrets/encrypted which only exists on :1984.
        # This is set at LGP creation time via the bootstrap job so it persists in the LGP spec.
        LANGCHAIN_ENDPOINT: "http://langsmith-backend.langsmith.svc.cluster.local:1984"

  telemetry:
    usageReporting: true

postgres:
  external:
    enabled: true
    existingSecretName: "langsmith-postgres-secret"
    connectionUrlSecretKey: "connection_url"

redis:
  external:
    enabled: true
    existingSecretName: "langsmith-redis-secret"
    connectionUrlSecretKey: "connection_url"

# ── host-backend ──────────────────────────────────────────────────────────────
# SMITH_BACKEND_ENDPOINT must point to platform-backend:1986.
# The /auth?langgraph-api=true endpoint lives there — not on legacy backend:1984.

hostBackend:
  enabled: true
  deployment:
    labels:
      azure.workload.identity/use: "true"
    resources:
      requests: { cpu: "100m", memory: "500Mi" }
    env:
      - name: SMITH_BACKEND_ENDPOINT
        value: "http://langsmith-platform-backend.langsmith.svc.cluster.local:1986"
  serviceAccount:
    annotations:
      azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"

# ── listener ──────────────────────────────────────────────────────────────────
# DISABLED — each langgraph-dataplane-wsN release provides its own listener
# in its own namespace. The CP does not run a listener.

# listener:
#   enabled: false

# ── operator ──────────────────────────────────────────────────────────────────
# DISABLED — each dataplane namespace has its own independent operator.
# Leases are namespace-scoped: langgraph-dataplane-wsN/b578d67b.langchain.ai

operator:
  enabled: false

# ── backend ───────────────────────────────────────────────────────────────────

backend:
  deployment:
    replicas: 1
    labels:
      azure.workload.identity/use: "true"
    resources:
      requests: { cpu: 500m, memory: 1Gi }
      limits:   { cpu: 2000m, memory: 4Gi }
  serviceAccount:
    annotations:
      azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 1
      maxReplicas: 5
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

# ── Agent Builder servers ─────────────────────────────────────────────────────

agentBuilderToolServer:
  enabled: true
  deployment:
    labels:
      azure.workload.identity/use: "true"
    resources:
      requests: { cpu: 500m, memory: 1Gi }
      limits:   { cpu: 1000m, memory: 2Gi }
  serviceAccount:
    annotations:
      azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"

agentBuilderTriggerServer:
  enabled: true
  deployment:
    labels:
      azure.workload.identity/use: "true"
    resources:
      requests: { cpu: 500m, memory: 1Gi }
      limits:   { cpu: 1000m, memory: 2Gi }
  serviceAccount:
    annotations:
      azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"

# ── platformBackend ───────────────────────────────────────────────────────────

platformBackend:
  deployment:
    replicas: 1
    labels:
      azure.workload.identity/use: "true"
    resources:
      requests: { cpu: 500m, memory: 1Gi }
      limits:   { cpu: 1000m, memory: 2Gi }
    extraEnv: []
    # If using OIDC with session management, set max session duration:
    # - name: OAUTH_SESSION_MAX_SEC
    #   value: "86400"
  serviceAccount:
    annotations:
      azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 1
      maxReplicas: 10
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

# ── frontend ──────────────────────────────────────────────────────────────────
# Add LGP deployment URLs here AFTER agent deployments are created.
# Obtain current URLs from: kubectl get lgp -A -o wide
# Update lgp/<hash> values whenever agent-builder or clio deployments are re-created.

frontend:
  service:
    type: ClusterIP
  deployment:
    resources:
      requests: { cpu: 500m, memory: 1Gi }
      limits:   { cpu: 1000m, memory: 2Gi }
    extraEnv: []
    # Uncomment and fill in after agent deployments are created:
    # - name: VITE_AGENT_BUILDER_DEPLOYMENT_URL_PUBLIC
    #   value: "https://<your-domain.com>/lgp/<agent-builder-hash>"
    # - name: VITE_AGENT_BUILDER_GENERATOR_DEPLOYMENT_URL_PUBLIC
    #   value: "https://<your-domain.com>/lgp/<agent-builder-hash>"
    # - name: VITE_AGENT_BUILDER_MCP_SERVER_URL
    #   value: "https://<your-domain.com>/mcp"
    # - name: VITE_AGENT_BUILDER_TRIGGERS_API_URL
    #   value: "https://<your-domain.com>"
    # - name: CLIO_LANGGRAPH_URL
    #   value: "https://<your-domain.com>/lgp/<clio-hash>"
    # - name: VITE_POLLY_DEPLOYMENT_URL
    #   value: "https://<your-domain.com>/lgp/<polly-hash>"
    # - name: VITE_POLLY_CHARTS_ASSISTANT_ID
    #   value: "<polly-charts-assistant-uuid>"
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 1
      maxReplicas: 10
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

# ── queue / ingestQueue ───────────────────────────────────────────────────────

queue:
  deployment:
    replicas: 1
    labels:
      azure.workload.identity/use: "true"
    resources:
      requests: { cpu: 500m, memory: 1Gi }
      limits:   { cpu: 2000m, memory: 4Gi }
  serviceAccount:
    annotations:
      azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 1
      maxReplicas: 5
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

ingestQueue:
  enabled: true
  deployment:
    replicas: 1
    labels:
      azure.workload.identity/use: "true"
    resources:
      requests: { cpu: 500m, memory: 1Gi }
      limits:   { cpu: 2000m, memory: 4Gi }
  serviceAccount:
    annotations:
      azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 1
      maxReplicas: 5
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

# ── playground / aceBackend ───────────────────────────────────────────────────

playground:
  deployment:
    extraEnv: []
    resources:
      requests: { cpu: 500m, memory: 1Gi }
      limits:   { cpu: 1000m, memory: 2Gi }
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 1
      maxReplicas: 10
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

aceBackend:
  deployment:
    resources:
      requests: { cpu: 500m, memory: 1Gi }
      limits:   { cpu: 1000m, memory: 2Gi }
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 1
      maxReplicas: 5
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

# ── ClickHouse ────────────────────────────────────────────────────────────────
# Sized for Med/Med load: 16 vCPU / 64 GiB node (Standard_D16s_v3 large pool).
# Storage: 868 GiB per sizing calculator (Med/Med, 14d TTL).
# ClickHouse requires SSD with 7,000+ IOPS and 1,000 MiB/s throughput.

clickhouse:
  statefulSet:
    resources:
      requests: { cpu: 4000m, memory: 16Gi }
      limits:   { cpu: 16000m, memory: 48Gi }
    persistence:
      size: "868Gi"

# ── commonEnv ─────────────────────────────────────────────────────────────────
# Required for Agent Builder (multi-dataplane).
# Add LANGGRAPH_API_URL_PUBLIC AFTER the agent-builder deployment is created.
# Update lgp/<hash> whenever agent-builder deployment is re-created.
# Ref: https://kb.langchain.com/articles/5436738584

commonEnv:
  # - name: LANGGRAPH_API_URL_PUBLIC
  #   value: "https://<your-domain.com>/lgp/<agent-builder-hash>"
  # Disable JIT provisioning for self-hosted — SCIM is the single provisioning source.
  # Requires chart >= 0.11.14. API-based disable (PATCH /orgs/current/info) is cloud-only.
  - name: SELF_HOSTED_JIT_PROVISIONING_ENABLED
    value: "false"

# ── Ingress / Gateway ─────────────────────────────────────────────────────────
# Istio Gateway for LangSmith core + all agent deployments across namespaces.
# istioGateway creates VirtualService resources — routes traffic across namespaces
# to agent deployments. Standard Ingress is namespace-scoped and cannot do this.

ingress:
  enabled: false

istioGateway:
  enabled: true
  name: "langsmith-gateway"
  namespace: "aks-istio-ingress"   # ASM addon: ingress gateway lives in aks-istio-ingress (not istio-system)
