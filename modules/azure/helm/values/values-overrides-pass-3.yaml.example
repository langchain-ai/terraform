# LangSmith Azure — Pass 3: LangGraph Platform (Deployments)
#
# Adds to Pass 2: host-backend, listener, operator — 20 pods total
#
# Prerequisites:
#   - Pass 2 deployed and healthy
#   - KEDA installed (Pass 1 Terraform)
#   - config.deployment.enabled: true  ← required or listener/operator won't deploy
#
# HOW TO USE:
#   cp values-overrides-pass-3.yaml.example values-overrides.yaml
#   Fill every <placeholder> with real values from terraform outputs.
#   values-overrides.yaml is gitignored — never commit it.
#
# HELM COMMAND:
#   helm upgrade --install langsmith langsmith/langsmith \
#     --version <VERSION> --namespace langsmith \
#     -f helm/values/values-overrides.yaml \
#     --wait --timeout 15m

config:
  hostname: "<your-domain.com>"
  authType: "mixed"
  initialOrgAdminEmail: "<admin@example.com>"
  existingSecretName: "langsmith-config-secret"
  basicAuth:
    enabled: true
  blobStorage:
    enabled: true
    engine: "Azure"
    azureStorageAccountName: "<tf output: storage_account_name>"
    azureStorageContainerName: "<tf output: storage_container_name>"
  telemetry:
    usageReporting: true
  # Pass 3 — required: both enabled AND url
  deployment:
    enabled: true
    url: "https://<your-domain.com>"           # must match config.hostname

postgres:
  external:
    enabled: true
    existingSecretName: "langsmith-postgres-secret"
    connectionUrlSecretKey: "connection_url"

redis:
  external:
    enabled: true
    existingSecretName: "langsmith-redis-secret"
    connectionUrlSecretKey: "connection_url"

backend:
  deployment:
    replicas: 1
    labels:
      azure.workload.identity/use: "true"
    resources:
      requests: { cpu: 1000m, memory: 2000Mi }
      limits:   { cpu: 2000m, memory: 4Gi }
  serviceAccount:
    annotations:
      azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 3
      maxReplicas: 10
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

platformBackend:
  deployment:
    replicas: 1
    labels:
      azure.workload.identity/use: "true"
    resources:
      requests: { cpu: 1000m, memory: 2Gi }
      limits:   { cpu: 2000m, memory: 4Gi }
  serviceAccount:
    annotations:
      azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 1
      maxReplicas: 10
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

frontend:
  service:
    type: ClusterIP
  deployment:
    resources:
      requests: { cpu: 500m, memory: 1Gi }
      limits:   { cpu: 1000m, memory: 2Gi }
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 1
      maxReplicas: 10
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

playground:
  deployment:
    resources:
      requests: { cpu: 500m, memory: 1Gi }
      limits:   { cpu: 1000m, memory: 2Gi }
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 1
      maxReplicas: 10
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

queue:
  deployment:
    replicas: 1
    labels:
      azure.workload.identity/use: "true"
    resources:
      requests: { cpu: 1000m, memory: 2Gi }
      limits:   { cpu: 2000m, memory: 4Gi }
  serviceAccount:
    annotations:
      azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 3
      maxReplicas: 10
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

ingestQueue:
  enabled: true
  deployment:
    replicas: 1
    labels:
      azure.workload.identity/use: "true"
    resources:
      requests: { cpu: 1000m, memory: 2Gi }
      limits:   { cpu: 2000m, memory: 4Gi }
  serviceAccount:
    annotations:
      azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 3
      maxReplicas: 10
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

aceBackend:
  deployment:
    resources:
      requests: { cpu: 500m, memory: 1Gi }
      limits:   { cpu: 1000m, memory: 2Gi }
  autoscaling:
    hpa:
      enabled: true
      minReplicas: 1
      maxReplicas: 5
      targetCPUUtilizationPercentage: 50
      targetMemoryUtilizationPercentage: 80

clickhouse:
  statefulSet:
    resources:
      requests: { cpu: 3500m, memory: 15Gi }
      limits:   { cpu: 8000m, memory: 32Gi }
    persistence:
      size: "500Gi"

# ── Ingress / Gateway ─────────────────────────────────────────────────────────
# Choose based on ingress_controller in terraform.tfvars:
#
# Option A — istio-addon (required for multi-dataplane)
#   istioGateway creates VirtualService resources — routes traffic across
#   namespaces to agent deployments. Standard Ingress is namespace-scoped
#   and cannot do this.
ingress:
  enabled: false

istioGateway:
  enabled: true
  name: "langsmith-gateway"    # must match the Gateway resource on the cluster
  namespace: "aks-istio-ingress"   # ASM addon: ingress gateway lives in aks-istio-ingress (not istio-system)
# Option B — NGINX (simpler, single-namespace deployments only)
# ingress:
#   enabled: true
#   ingressClassName: "nginx"
#   # Front Door: no annotations needed (TLS terminated at FD edge)
#   # cert-manager DNS-01: uncomment below
#   # annotations:
#   #   cert-manager.io/cluster-issuer: "letsencrypt-prod"
#   # tls:
#   #   - secretName: langsmith-tls
#   #     hosts:
#   #       - "<your-domain.com>"
# istioGateway:
#   enabled: false

# ── Pass 3 additions ──────────────────────────────────────────────────────────
hostBackend:
  enabled: true
  deployment:
    labels:
      azure.workload.identity/use: "true"
    resources:
      requests: { cpu: 200m, memory: 1Gi }
      limits:   { cpu: 1000m, memory: 2Gi }
  serviceAccount:
    annotations:
      azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"

listener:
  enabled: true
  deployment:
    labels:
      azure.workload.identity/use: "true"
    resources:
      requests: { cpu: 1000m, memory: 2Gi }
      limits:   { cpu: 2000m, memory: 4Gi }
  serviceAccount:
    annotations:
      azure.workload.identity/client-id: "<tf output: workload_identity_client_id>"

operator:
  enabled: true
  # Azure deployment template — WI label + langsmith-ksa so every LangGraph
  # agent deployment pod can access Blob Storage via Workload Identity.
  templates:
    deployment: |
      apiVersion: apps/v1
      kind: Deployment
      metadata:
        name: ${name}
        namespace: ${namespace}
      spec:
        replicas: ${replicas}
        revisionHistoryLimit: 10
        selector:
          matchLabels:
            app: ${name}
        template:
          metadata:
            labels:
              app: ${name}
              azure.workload.identity/use: "true"
          spec:
            enableServiceLinks: false
            serviceAccountName: langsmith-ksa
            containers:
            - name: api-server
              image: ${image}
              ports:
              - name: api-server
                containerPort: 8000
                protocol: TCP
              livenessProbe:
                httpGet:
                  path: /ok
                  port: 8000
                periodSeconds: 15
                timeoutSeconds: 5
                failureThreshold: 6
              readinessProbe:
                httpGet:
                  path: /ok
                  port: 8000
                periodSeconds: 15
                timeoutSeconds: 5
                failureThreshold: 6
              resources:
                requests:
                  cpu: 100m
                  memory: 256Mi
                limits:
                  cpu: 1000m
                  memory: 1Gi
