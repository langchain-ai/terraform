[
  {
    "Sid": "S3BucketRead",
    "Effect": "Allow",
    "Action": [
      "s3:GetAccelerateConfiguration",
      "s3:GetBucketAcl",
      "s3:GetBucketCORS",
      "s3:GetBucketLocation",
      "s3:GetBucketLogging",
      "s3:GetBucketNotification",
      "s3:GetBucketObjectLockConfiguration",
      "s3:GetBucketOwnershipControls",
      "s3:GetBucketPolicy",
      "s3:GetBucketPublicAccessBlock",
      "s3:GetBucketRequestPayment",
      "s3:GetBucketTagging",
      "s3:GetBucketVersioning",
      "s3:GetBucketWebsite",
      "s3:GetEncryptionConfiguration",
      "s3:GetLifecycleConfiguration",
      "s3:GetReplicationConfiguration",
      "s3:ListBucket"
    ],
    "Resource": [
      "arn:aws:s3:::*-smith-blob",
      "arn:aws:s3:::*-smith-clickhouse-backups",
      "arn:aws:s3:::*-smith-vpc-flow-logs"
    ]
  },
  {
    "Sid": "S3BucketTag",
    "Effect": "Allow",
    "Action": ["s3:PutBucketTagging"],
    "Resource": [
      "arn:aws:s3:::*-smith-blob",
      "arn:aws:s3:::*-smith-clickhouse-backups",
      "arn:aws:s3:::*-smith-vpc-flow-logs",
      "arn:aws:s3:::*-smith-sandbox-snapshots"
    ]
  },
  {
    "Sid": "S3BucketEncryptionConfig",
    "Effect": "Allow",
    "Action": ["s3:PutEncryptionConfiguration"],
    "Resource": [
      "arn:aws:s3:::*-smith-blob",
      "arn:aws:s3:::*-smith-clickhouse-backups",
      "arn:aws:s3:::*-smith-vpc-flow-logs",
      "arn:aws:s3:::*-smith-sandbox-snapshots"
    ]
  },
  {
    "Sid": "S3DenyObjectDataAccess",
    "Effect": "Deny",
    "Action": "s3:*",
    "Resource": "arn:aws:s3:::*/*"
  }
]
