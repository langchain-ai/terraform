[
  {
    "Sid": "EC2DetachNetworkInterface",
    "Effect": "Allow",
    "Action": ["ec2:DetachNetworkInterface"],
    "Resource": [
      "arn:aws:ec2:*:${account_id}:network-interface/*",
      "arn:aws:ec2:*:${account_id}:instance/*"
    ],
    "Condition": {
      "StringEquals": {
        "aws:ResourceTag/managed_by": "langsmith"
      }
    }
  }
]
