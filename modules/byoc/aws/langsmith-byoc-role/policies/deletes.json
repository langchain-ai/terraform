    "Sid": "ACMDeleteTaggedCertificates",
    "Effect": "Allow",
    "Action": [
      "acm:DeleteCertificate",
      "acm:RemoveTagsFromCertificate"
    ],
    "Resource": "arn:aws:acm:*:${account_id}:certificate/*",
    "Condition": {
      "StringEquals": {
        "aws:ResourceTag/managed_by": "langsmith"
      }
    }
  },
