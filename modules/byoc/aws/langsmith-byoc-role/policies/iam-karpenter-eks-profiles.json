[
  {
    "Sid": "IAMInstanceProfileCreate",
    "Effect": "Allow",
    "Action": ["iam:CreateInstanceProfile"],
    "Resource": "arn:aws:iam::${account_id}:instance-profile/*-smith-karpenter-node-profile",
    "Condition": {
      "StringEquals": {
        "aws:RequestTag/managed_by": "langsmith"
      }
    }
  },
  {
    "Sid": "IAMInstanceProfileRead",
    "Effect": "Allow",
    "Action": ["iam:GetInstanceProfile"],
    "Resource": "arn:aws:iam::${account_id}:instance-profile/*-smith-karpenter-node-profile"
  },
  {
    "Sid": "IAMInstanceProfileManage",
    "Effect": "Allow",
    "Action": [
      "iam:AddRoleToInstanceProfile",
      "iam:RemoveRoleFromInstanceProfile",
      "iam:TagInstanceProfile",
      "iam:UntagInstanceProfile"
    ],
    "Resource": "arn:aws:iam::${account_id}:instance-profile/*-smith-karpenter-node-profile",
    "Condition": {
      "StringEquals": {
        "aws:ResourceTag/managed_by": "langsmith"
      }
    }
  },
  {
    "Sid": "IAMEKSInstanceProfileRead",
    "Effect": "Allow",
    "Action": ["iam:GetInstanceProfile"],
    "Resource": "arn:aws:iam::${account_id}:instance-profile/eks-*"
  },
  {
    "Sid": "IAMEKSInstanceProfileManage",
    "Effect": "Allow",
    "Action": ["iam:RemoveRoleFromInstanceProfile"],
    "Resource": "arn:aws:iam::${account_id}:instance-profile/eks-*",
    "Condition": {
      "StringLike": {
        "aws:ResourceTag/eks:cluster-name": "*-smith*"
      }
    }
  },
  {
    "Sid": "IAMPolicyCreate",
    "Effect": "Allow",
    "Action": ["iam:CreatePolicy"],
    "Resource": "arn:aws:iam::${account_id}:policy/*-smith-karpenter-controller-policy",
    "Condition": {
      "StringEquals": {
        "aws:RequestTag/managed_by": "langsmith"
      }
    }
  },
  {
    "Sid": "IAMPolicyRead",
    "Effect": "Allow",
    "Action": [
      "iam:GetPolicy",
      "iam:GetPolicyVersion",
      "iam:ListPolicyVersions"
    ],
    "Resource": "arn:aws:iam::${account_id}:policy/*-smith-karpenter-controller-policy"
  },
  {
    "Sid": "IAMPolicyManage",
    "Effect": "Allow",
    "Action": [
      "iam:CreatePolicyVersion",
      "iam:TagPolicy",
      "iam:UntagPolicy"
    ],
    "Resource": "arn:aws:iam::${account_id}:policy/*-smith-karpenter-controller-policy",
    "Condition": {
      "StringEquals": {
        "aws:ResourceTag/managed_by": "langsmith"
      }
    }
  },
  {
    "Sid": "IAMPassRole",
    "Effect": "Allow",
    "Action": ["iam:PassRole"],
    "Resource": [
      "arn:aws:iam::${account_id}:role/*-smith-postgres-monitoring-role",
      "arn:aws:iam::${account_id}:role/*-smith-eks-cluster-role",
      "arn:aws:iam::${account_id}:role/*-smith-ebs-csi-role",
      "arn:aws:iam::${account_id}:role/*-smith-eks-node-role",
      "arn:aws:iam::${account_id}:role/*-smith-workload-iam-role",
      "arn:aws:iam::${account_id}:role/*-smith-external-secrets-iam-role",
      "arn:aws:iam::${account_id}:role/*-smith-karpenter-node-role",
      "arn:aws:iam::${account_id}:role/*-smith-karpenter-controller-role",
      "arn:aws:iam::${account_id}:role/*-smith-privatelink-lambda-role",
      "arn:aws:iam::${account_id}:role/*-smith-lbc-role",
      "arn:aws:iam::${account_id}:role/*-smith-ch-backup-role",
      "arn:aws:iam::${account_id}:role/*-smith-juicefs-csi-iam-role"
    ],
    "Condition": {
      "StringEquals": {
        "iam:PassedToService": [
          "eks.amazonaws.com",
          "ec2.amazonaws.com",
          "pods.eks.amazonaws.com",
          "monitoring.rds.amazonaws.com",
          "lambda.amazonaws.com"
        ]
      }
    }
  }
]
