[
  {
    "Sid": "EKSDescribe",
    "Effect": "Allow",
    "Action": ["eks:Describe*", "eks:List*"],
    "Resource": "*"
  },
  {
    "Sid": "EKSClusterCreate",
    "Effect": "Allow",
    "Action": ["eks:CreateCluster"],
    "Resource": "arn:aws:eks:*:${account_id}:cluster/*-smith-eks",
    "Condition": {
      "StringEquals": {
        "aws:RequestTag/managed_by": "langsmith"
      }
    }
  },
  {
    "Sid": "EKSClusterManage",
    "Effect": "Allow",
    "Action": [
      "eks:DeleteCluster",
      "eks:UpdateClusterConfig",
      "eks:UpdateClusterVersion",
      "eks:AccessKubernetesApi",
      "eks:TagResource",
      "eks:UntagResource"
    ],
    "Resource": "arn:aws:eks:*:${account_id}:cluster/*-smith-eks",
    "Condition": {
      "StringEquals": {
        "aws:ResourceTag/managed_by": "langsmith"
      }
    }
  },
  {
    "Sid": "EKSNodegroupCreate",
    "Effect": "Allow",
    "Action": ["eks:CreateNodegroup"],
    "Resource": "arn:aws:eks:*:${account_id}:cluster/*-smith-eks",
    "Condition": {
      "StringEquals": {
        "aws:RequestTag/managed_by": "langsmith"
      }
    }
  },
  {
    "Sid": "EKSNodegroupManage",
    "Effect": "Allow",
    "Action": [
      "eks:DeleteNodegroup",
      "eks:UpdateNodegroupConfig",
      "eks:UpdateNodegroupVersion",
      "eks:TagResource",
      "eks:UntagResource"
    ],
    "Resource": "arn:aws:eks:*:${account_id}:nodegroup/*-smith-eks/*/*",
    "Condition": {
      "StringEquals": {
        "aws:ResourceTag/managed_by": "langsmith"
      }
    }
  },
  {
    "Sid": "EKSAddonCreate",
    "Effect": "Allow",
    "Action": ["eks:CreateAddon"],
    "Resource": "arn:aws:eks:*:${account_id}:cluster/*-smith-eks",
    "Condition": {
      "StringEquals": {
        "aws:RequestTag/managed_by": "langsmith"
      }
    }
  },
  {
    "Sid": "EKSAddonManage",
    "Effect": "Allow",
    "Action": [
      "eks:DeleteAddon",
      "eks:UpdateAddon",
      "eks:TagResource",
      "eks:UntagResource"
    ],
    "Resource": "arn:aws:eks:*:${account_id}:addon/*-smith-eks/*/*",
    "Condition": {
      "StringEquals": {
        "aws:ResourceTag/managed_by": "langsmith"
      }
    }
  },
  {
    "Sid": "EKSAccessEntryCreate",
    "Effect": "Allow",
    "Action": ["eks:CreateAccessEntry"],
    "Resource": "arn:aws:eks:*:${account_id}:cluster/*-smith-eks",
    "Condition": {
      "StringEquals": {
        "aws:RequestTag/managed_by": "langsmith"
      }
    }
  },
  {
    "Sid": "EKSAccessEntryManage",
    "Effect": "Allow",
    "Action": [
      "eks:DeleteAccessEntry",
      "eks:AssociateAccessPolicy",
      "eks:DisassociateAccessPolicy",
      "eks:TagResource",
      "eks:UntagResource"
    ],
    "Resource": "arn:aws:eks:*:${account_id}:access-entry/*-smith-eks/*",
    "Condition": {
      "StringEquals": {
        "aws:ResourceTag/managed_by": "langsmith"
      }
    }
  },
  {
    "Sid": "EKSPodIdentityCreate",
    "Effect": "Allow",
    "Action": ["eks:CreatePodIdentityAssociation"],
    "Resource": "arn:aws:eks:*:${account_id}:cluster/*-smith-eks",
    "Condition": {
      "StringEquals": {
        "aws:RequestTag/managed_by": "langsmith"
      }
    }
  },
  {
    "Sid": "EKSPodIdentityManage",
    "Effect": "Allow",
    "Action": [
      "eks:DeletePodIdentityAssociation",
      "eks:UpdatePodIdentityAssociation",
      "eks:TagResource",
      "eks:UntagResource"
    ],
    "Resource": "arn:aws:eks:*:${account_id}:podidentityassociation/*-smith-eks/*",
    "Condition": {
      "StringEquals": {
        "aws:ResourceTag/managed_by": "langsmith"
      }
    }
  },
  {
    "Sid": "EC2LaunchTemplateCreate",
    "Effect": "Allow",
    "Action": ["ec2:CreateLaunchTemplate"],
    "Resource": ["arn:aws:ec2:*:${account_id}:launch-template/*"],
    "Condition": {
      "StringEquals": {
        "aws:RequestTag/managed_by": "langsmith"
      }
    }
  },
  {
    "Sid": "EC2LaunchTemplateManage",
    "Effect": "Allow",
    "Action": [
      "ec2:CreateLaunchTemplateVersion",
      "ec2:ModifyLaunchTemplate",
      "ec2:DeleteLaunchTemplate",
      "ec2:DeleteLaunchTemplateVersions"
    ],
    "Resource": ["arn:aws:ec2:*:${account_id}:launch-template/*"],
    "Condition": {
      "StringEquals": {
        "aws:ResourceTag/managed_by": "langsmith"
      }
    }
  },
  {
    "Sid": "EC2LaunchTemplateCreateTags",
    "Effect": "Allow",
    "Action": ["ec2:CreateTags"],
    "Resource": ["arn:aws:ec2:*:${account_id}:launch-template/*"],
    "Condition": {
      "StringEquals": {
        "aws:RequestTag/managed_by": "langsmith",
        "ec2:CreateAction": "CreateLaunchTemplate"
      }
    }
  },
  {
    "Sid": "EC2LaunchTemplateManageTags",
    "Effect": "Allow",
    "Action": ["ec2:CreateTags", "ec2:DeleteTags"],
    "Resource": ["arn:aws:ec2:*:${account_id}:launch-template/*"],
    "Condition": {
      "StringEquals": {
        "aws:ResourceTag/managed_by": "langsmith"
      }
    }
  },
  {
    "Sid": "EC2RunInstancesManagedLaunchTemplate",
    "Effect": "Allow",
    "Action": ["ec2:RunInstances"],
    "Resource": ["arn:aws:ec2:*:${account_id}:launch-template/*"],
    "Condition": {
      "StringEquals": {
        "aws:ResourceTag/managed_by": "langsmith"
      }
    }
  },
  {
    "Sid": "EC2RunInstancesLaunchResources",
    "Effect": "Allow",
    "Action": ["ec2:RunInstances"],
    "Resource": [
      "arn:aws:ec2:*:${account_id}:instance/*",
      "arn:aws:ec2:*:${account_id}:volume/*",
      "arn:aws:ec2:*:${account_id}:network-interface/*",
      "arn:aws:ec2:*:${account_id}:security-group/*",
      "arn:aws:ec2:*:${account_id}:subnet/*",
      "arn:aws:ec2:*:${account_id}:key-pair/*",
      "arn:aws:ec2:*::image/*"
    ],
    "Condition": {
      "ArnLike": {
        "ec2:LaunchTemplate": "arn:aws:ec2:*:${account_id}:launch-template/*"
      },
      "StringLikeIfExists": {
        "ec2:InstanceType": ["c8i*.*", "m8i*.*", "r8i*.*"]
      }
    }
  }
]
