        "StringEquals": {
          "aws:ResourceTag/managed_by": "langsmith"
        }
      }
    },
    {
      "Sid": "EKSNodegroupDelete",
      "Effect": "Allow",
      "Action": ["eks:DeleteNodegroup"],
      "Resource": "arn:aws:eks:*:${account_id}:nodegroup/*-smith-eks/*/*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/managed_by": "langsmith"
        }
      }
    },
    {
      "Sid": "EKSAddonDelete",
      "Effect": "Allow",
      "Action": ["eks:DeleteAddon"],
      "Resource": "arn:aws:eks:*:${account_id}:addon/*-smith-eks/*/*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/managed_by": "langsmith"
        }
      }
    },
    {
      "Sid": "EKSAccessEntryDelete",
      "Effect": "Allow",
      "Action": ["eks:DeleteAccessEntry"],
      "Resource": "arn:aws:eks:*:${account_id}:access-entry/*-smith-eks/*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/managed_by": "langsmith"
        }
      }
    },
    {
      "Sid": "EKSPodIdentityDelete",
      "Effect": "Allow",
      "Action": ["eks:DeletePodIdentityAssociation"],
      "Resource": "arn:aws:eks:*:${account_id}:podidentityassociation/*-smith-eks/*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/managed_by": "langsmith"
        }
      }
    }
  ],
  "elbv2": [
    {
      "Sid": "ELBv2LoadBalancerDelete",
      "Effect": "Allow",
      "Action": ["elasticloadbalancing:DeleteLoadBalancer"],
      "Resource": "arn:aws:elasticloadbalancing:*:${account_id}:loadbalancer/net/*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/managed_by": "langsmith"
        }
      }
    },
    {
      "Sid": "ELBv2TargetGroupDelete",
      "Effect": "Allow",
      "Action": ["elasticloadbalancing:DeleteTargetGroup"],
      "Resource": "arn:aws:elasticloadbalancing:*:${account_id}:targetgroup/*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/managed_by": "langsmith"
        }
      }
    },
    {
      "Sid": "ELBv2ListenerDelete",
      "Effect": "Allow",
      "Action": ["elasticloadbalancing:DeleteListener"],
      "Resource": "arn:aws:elasticloadbalancing:*:${account_id}:listener/net/*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/managed_by": "langsmith"
        }
      }
    }
  ],
  "data": [
    {
      "Sid": "RDSInstanceDelete",
      "Effect": "Allow",
      "Action": ["rds:DeleteDBInstance"],
      "Resource": "arn:aws:rds:*:${account_id}:db:*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/managed_by": "langsmith"
        }
      }
    },
    {
      "Sid": "RDSSubnetGroupDelete",
      "Effect": "Allow",
      "Action": ["rds:DeleteDBSubnetGroup"],
      "Resource": "arn:aws:rds:*:${account_id}:subgrp:*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/managed_by": "langsmith"
        }
      }
    },
    {
      "Sid": "SecretsManagerDeleteForRDS",
      "Effect": "Allow",
      "Action": ["secretsmanager:DeleteSecret"],
      "Resource": "arn:aws:secretsmanager:*:${account_id}:secret:rds!*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/managed_by": "langsmith"
        }
      }
    },
    {
      "Sid": "SecretsManagerDeleteForLangsmith",
      "Effect": "Allow",
      "Action": ["secretsmanager:DeleteSecret"],
      "Resource": "arn:aws:secretsmanager:*:${account_id}:secret:langsmith/*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/managed_by": "langsmith"
        }
      }
    }
  ],
  "storage": [
    {
      "Sid": "ElastiCacheReplicationGroupDelete",
      "Effect": "Allow",
      "Action": ["elasticache:DeleteReplicationGroup"],
      "Resource": [
        "arn:aws:elasticache:*:${account_id}:cluster:*",
        "arn:aws:elasticache:*:${account_id}:parametergroup:*-smith-redis-pg",
        "arn:aws:elasticache:*:${account_id}:replicationgroup:*"
      ],
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/managed_by": "langsmith"
        }
      }
    },
    {
      "Sid": "ElastiCacheSubnetGroupDelete",
      "Effect": "Allow",
      "Action": ["elasticache:DeleteCacheSubnetGroup"],
      "Resource": "arn:aws:elasticache:*:${account_id}:subnetgroup:*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/managed_by": "langsmith"
        }
      }
    },
    {
      "Sid": "ElastiCacheUserDelete",
      "Effect": "Allow",
      "Action": [
        "elasticache:DeleteUser",
        "elasticache:DeleteUserGroup"
      ],
      "Resource": [
        "arn:aws:elasticache:*:${account_id}:user:*",
        "arn:aws:elasticache:*:${account_id}:usergroup:*"
      ],
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/managed_by": "langsmith"
        }
      }
    }
  ],
  "lambda": [
    {
      "Sid": "LambdaFunctionDelete",
      "Effect": "Allow",
      "Action": ["lambda:DeleteFunction"],
      "Resource": [
        "arn:aws:lambda:*:${account_id}:function:*-smith-add-eni-ips",
        "arn:aws:lambda:*:${account_id}:function:*-smith-add-eni-ips:*",
        "arn:aws:lambda:*:${account_id}:function:*-smith-update-eni-ips",
        "arn:aws:lambda:*:${account_id}:function:*-smith-update-eni-ips:*"
      ],
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/managed_by": "langsmith"
        }
      }
    },
    {
      "Sid": "EventBridgeDeleteRule",
      "Effect": "Allow",
      "Action": ["events:DeleteRule"],
      "Resource": [
        "arn:aws:events:*:${account_id}:rule/*-smith-eks-eni-create",
        "arn:aws:events:*:${account_id}:rule/*-smith-eks-eni-cleanup"
      ],
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/managed_by": "langsmith"
        }
      }
    }
  ],
  "dns": [
    {
      "Sid": "Route53DeletePrivateHostedZone",
      "Effect": "Allow",
      "Action": ["route53:DeleteHostedZone"],
      "Resource": "arn:aws:route53:::hostedzone/*"
    },
    {
      "Sid": "Route53DeleteLangsmithRecords",
      "Effect": "Allow",
      "Action": ["route53:ChangeResourceRecordSets"],
      "Resource": "arn:aws:route53:::hostedzone/*",
      "Condition": {
        "ForAllValues:StringEquals": {
          "route53:ChangeResourceRecordSetsRecordTypes": ["A"],
          "route53:ChangeResourceRecordSetsActions": ["DELETE"]
        },
        "ForAllValues:StringLike": {
          "route53:ChangeResourceRecordSetsNormalizedRecordNames": [
            "*.eks.amazonaws.com",
            "*.smith.langchain.com",
            "*.aws.langchain-byoc.com",
            "beacon.*.langchain.com"
          ]
        }
      }
    },
    {
      "Sid": "ACMCertificateDelete",
      "Effect": "Allow",
      "Action": ["acm:DeleteCertificate"],
      "Resource": "arn:aws:acm:*:${account_id}:certificate/*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/managed_by": "langsmith"
        }
      }
    }
  ],
  "dns-public": [
    {
      "Sid": "Route53DeleteAcmValidationRecords",
      "Effect": "Allow",
      "Action": ["route53:ChangeResourceRecordSets"],
      "Resource": "arn:aws:route53:::hostedzone/*",
      "Condition": {
        "ForAllValues:StringEquals": {
          "route53:ChangeResourceRecordSetsRecordTypes": ["CNAME"],
          "route53:ChangeResourceRecordSetsActions": ["DELETE"]
        },
        "ForAllValues:StringLike": {
          "route53:ChangeResourceRecordSetsNormalizedRecordNames": [
            "*.aws.langchain-byoc.com"
          ]
        }
      }
    }
  ]
}
