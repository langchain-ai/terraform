{
  "vpc": [
    {
      "Sid": "EC2DeleteManagedResources",
      "Effect": "Allow",
      "Action": [
        "ec2:DeleteVpc",
        "ec2:DeleteSubnet",
        "ec2:DeleteInternetGateway",
        "ec2:DeleteNatGateway",
        "ec2:DeleteRouteTable",
        "ec2:DeleteSecurityGroup",
        "ec2:ReleaseAddress",
        "ec2:DeleteVpcEndpoints",
        "ec2:DeleteVpcEndpointServiceConfigurations",
        "ec2:DeleteFlowLogs",
        "ec2:DeleteRoute"
      ],
      "Resource": [
        "arn:aws:ec2:*:${account_id}:vpc/*",
        "arn:aws:ec2:*:${account_id}:subnet/*",
        "arn:aws:ec2:*:${account_id}:internet-gateway/*",
        "arn:aws:ec2:*:${account_id}:natgateway/*",
        "arn:aws:ec2:*:${account_id}:route-table/*",
        "arn:aws:ec2:*:${account_id}:security-group/*",
        "arn:aws:ec2:*:${account_id}:security-group-rule/*",
        "arn:aws:ec2:*:${account_id}:elastic-ip/*",
        "arn:aws:ec2:*:${account_id}:vpc-endpoint/*",
        "arn:aws:ec2:*:${account_id}:vpc-endpoint-service/*",
        "arn:aws:ec2:*:${account_id}:vpc-flow-log/*",
        "arn:aws:ec2:*:${account_id}:network-acl/*"
      ],
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/managed_by": "langsmith"
        }
      }
    },
    {
      "Sid": "CloudWatchLogsDeleteDeliveryForVpcFlowLogs",
      "Effect": "Allow",
      "Action": ["logs:DeleteLogDelivery"],
      "Resource": "*"
    }
  ],
  "iam": [
    {
      "Sid": "IAMRoleDelete",
      "Effect": "Allow",
      "Action": [
        "iam:DeleteRole",
        "iam:DeleteRolePolicy"
      ],
      "Resource": [
        "arn:aws:iam::${account_id}:role/*-smith-postgres-monitoring-role",
        "arn:aws:iam::${account_id}:role/*-smith-eks-cluster-role",
        "arn:aws:iam::${account_id}:role/*-smith-ebs-csi-role",
        "arn:aws:iam::${account_id}:role/*-smith-eks-node-role",
        "arn:aws:iam::${account_id}:role/*-smith-sandbox-node-role",
        "arn:aws:iam::${account_id}:role/*-smith-workload-iam-role",
        "arn:aws:iam::${account_id}:role/*-smithbox-control-iam-role",
        "arn:aws:iam::${account_id}:role/*-smith-external-secrets-iam-role",
        "arn:aws:iam::${account_id}:role/*-smith-karpenter-node-role",
        "arn:aws:iam::${account_id}:role/*-smith-karpenter-controller-role",
        "arn:aws:iam::${account_id}:role/*-smith-privatelink-lambda-role",
        "arn:aws:iam::${account_id}:role/*-smith-lbc-role",
        "arn:aws:iam::${account_id}:role/*-smith-ch-backup-role",
        "arn:aws:iam::${account_id}:role/*-smith-juicefs-csi-iam-role"
      ],
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/managed_by": "langsmith"
        }
      }
    }
  ],
  "iam-karpenter-eks-profiles": [
    {
      "Sid": "IAMInstanceProfileDelete",
      "Effect": "Allow",
      "Action": ["iam:DeleteInstanceProfile"],
      "Resource": "arn:aws:iam::${account_id}:instance-profile/*-smith-karpenter-node-profile",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/managed_by": "langsmith"
        }
      }
    },
    {
      "Sid": "IAMPolicyDelete",
      "Effect": "Allow",
      "Action": [
        "iam:DeletePolicy",
        "iam:DeletePolicyVersion"
      ],
      "Resource": "arn:aws:iam::${account_id}:policy/*-smith-karpenter-controller-policy",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/managed_by": "langsmith"
        }
      }
    }
  ],
  "eks": [
    {
      "Sid": "EKSClusterDelete",
      "Effect": "Allow",
      "Action": ["eks:DeleteCluster"],
      "Resource": "arn:aws:eks:*:${account_id}:cluster/*-smith-eks",
